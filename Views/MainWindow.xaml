<Window x:Class="ApEn.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ApEn.ViewModels"
        xmlns:conv="clr-namespace:ApEn.Converters"
        Title="ApEn — App &amp; File Environment"
        Height="700" Width="1100"
        MinHeight="540" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="{DynamicResource BrushBgDark}"
        MouseDown="Window_MouseDown">

    <Window.DataContext><vm:MainViewModel/></Window.DataContext>
    <Window.Resources>
        <conv:TabVisibilityConverter           x:Key="TabVis"/>
        <conv:TabWeightConverter               x:Key="TabWeight"/>
        <conv:TabColorConverter                x:Key="TabColor"/>
        <conv:ZeroToVisibilityConverter        x:Key="ZeroVis"/>
        <conv:NonZeroToVisibilityConverter     x:Key="NonZeroVis"/>
        <conv:BoolToVisibilityConverter        x:Key="BoolVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolVis"/>
        <conv:BoolToStringConverter            x:Key="BoolStr"/>
        <conv:HexToBrushConverter              x:Key="HexBrush"/>
        <conv:CollectionContainsBoolConverter  x:Key="ColContains"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Grid Grid.Row="0" Background="{DynamicResource BrushBgPanel}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                <Image Source="pack://application:,,,/Assets/apen_logo.png"
                       Width="18" Height="18" Margin="0,0,7,0"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="ApEn" FontSize="13" FontWeight="Bold"
                           Foreground="{DynamicResource BrushAccent}" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
                <TextBlock Text="  App &amp; File Environment" FontFamily="Segoe UI" FontSize="11"
                           Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center"
                           Margin="4,0,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Style="{StaticResource BtnIcon}"
                        Command="{Binding SwitchTabCommand}" CommandParameter="0"
                        Padding="16,6" Margin="2,0">
                    <TextBlock FontFamily="Segoe UI" FontSize="13" Text="Launcher"
                               FontWeight="{Binding ActiveTab, Converter={StaticResource TabWeight}, ConverterParameter=0}"
                               Foreground="{Binding ActiveTab, Converter={StaticResource TabColor}, ConverterParameter=0}"/>
                </Button>
                <Rectangle Width="1" Height="12" Fill="{DynamicResource BrushBorder}" Margin="3,0"/>
                <Button Style="{StaticResource BtnIcon}"
                        Command="{Binding SwitchTabCommand}" CommandParameter="1"
                        Padding="16,6" Margin="2,0">
                    <TextBlock FontFamily="Segoe UI" FontSize="13" Text="Organizer"
                               FontWeight="{Binding ActiveTab, Converter={StaticResource TabWeight}, ConverterParameter=1}"
                               Foreground="{Binding ActiveTab, Converter={StaticResource TabColor}, ConverterParameter=1}"/>
                </Button>
            </StackPanel>
            <Button Grid.Column="2" Style="{StaticResource BtnSecondary}"
                    Command="{Binding ToggleThemeCommand}"
                    Padding="10,5" Margin="0,0,10,0" ToolTip="Cambiar entre tema oscuro y claro">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe UI" FontSize="13" Margin="0,0,5,0"
                               Text="{Binding IsDark, Converter={StaticResource BoolStr}, ConverterParameter='☀|🌙'}"
                               Foreground="{DynamicResource BrushTextSecondary}"/>
                    <TextBlock FontFamily="Segoe UI" FontSize="11"
                               Text="{Binding IsDark, Converter={StaticResource BoolStr}, ConverterParameter='Claro|Oscuro'}"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ══ CONTENIDO ══ -->
        <Grid Grid.Row="1">

            <!-- ─── TAB 0: LAUNCHER ─── -->
            <Grid Visibility="{Binding ActiveTab, Converter={StaticResource TabVis}, ConverterParameter=0}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ══ LISTA DE APPS ══ -->
                <Grid Grid.Column="0" Background="{DynamicResource BrushBgPanel}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- Header -->
                        <RowDefinition Height="*"/>       <!-- Lista -->
                    </Grid.RowDefinitions>

                    <!-- Header: contador + Filtrar dropdown + Add -->
                    <Border Grid.Row="0" Padding="12,10,12,10"
                            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="{DynamicResource BrushTextSecondary}">
                                <Run Text="{Binding Apps.Count, Mode=OneWay}"/>
                                <Run Text=" apps"/>
                            </TextBlock>

                            <!-- BOTÓN FILTRAR + POPUP -->
                            <Grid Grid.Column="1" Margin="0,0,6,0">
                                <!-- Botón que abre el popup -->
                                <Button x:Name="BtnFilterTrigger"
                                        Style="{StaticResource BtnSecondary}"
                                        Click="FilterButton_Click"
                                        Padding="10,6">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Indicador de filtros activos -->
                                        <Border Width="7" Height="7" CornerRadius="4"
                                                Background="{DynamicResource BrushAccent}"
                                                Margin="0,0,6,0" VerticalAlignment="Center"
                                                Visibility="{Binding ActiveTagFilters.Count, Converter={StaticResource NonZeroVis}}"/>
                                        <TextBlock FontFamily="Segoe UI" FontSize="12"
                                                   Foreground="{DynamicResource BrushTextSecondary}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="🏷 Filtrar"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActiveTagFilters.Count}" Value="0">
                                                            <Setter Property="Text" Value="🏷 Filtrar"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- Contador de filtros activos -->
                                        <Border CornerRadius="8" Padding="5,1" Margin="5,0,0,0"
                                                Background="{DynamicResource BrushAccent}"
                                                Visibility="{Binding ActiveTagFilters.Count, Converter={StaticResource NonZeroVis}}">
                                            <TextBlock FontFamily="Segoe UI" FontSize="10"
                                                       Foreground="White" FontWeight="Bold"
                                                       Text="{Binding ActiveTagFilters.Count}"/>
                                        </Border>
                                    </StackPanel>
                                </Button>

                                <!-- POPUP DROPDOWN de etiquetas -->
                                <Popup x:Name="TagFilterPopup"
                                       PlacementTarget="{Binding ElementName=BtnFilterTrigger}"
                                       Placement="Bottom"
                                       StaysOpen="False"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade">
                                    <Border MinWidth="220"
                                            Background="{DynamicResource BrushBgPanel}"
                                            BorderBrush="{DynamicResource BrushBorder}"
                                            BorderThickness="1"
                                            Margin="0,4,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="16" ShadowDepth="2"
                                                              Opacity="0.4" Color="#000000"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <!-- Header del popup -->
                                            <Border Padding="14,10,14,8"
                                                    BorderBrush="{DynamicResource BrushBorder}"
                                                    BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="FILTRAR POR ETIQUETA"
                                                               FontFamily="Segoe UI" FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource BrushTextSecondary}"
                                                               VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1"
                                                            Style="{StaticResource BtnIcon}"
                                                            Command="{Binding ClearTagFiltersCommand}"
                                                            Padding="6,3"
                                                            Visibility="{Binding ActiveTagFilters.Count, Converter={StaticResource NonZeroVis}}">
                                                        <TextBlock Text="Limpiar" FontFamily="Segoe UI"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource BrushAccent}"/>
                                                    </Button>
                                                </Grid>
                                            </Border>

                                            <!-- Lista de etiquetas como filas -->
                                            <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto">
                                                <StackPanel Margin="8,6,8,8">

                                                    <!-- Sin etiquetas -->
                                                    <TextBlock Text="Aún no has creado etiquetas."
                                                               FontFamily="Segoe UI" FontSize="12"
                                                               Foreground="{DynamicResource BrushTextSecondary}"
                                                               Padding="6,8" HorizontalAlignment="Center"
                                                               Visibility="{Binding AllTags.Count, Converter={StaticResource ZeroVis}}"/>

                                                    <!-- Una fila por etiqueta -->
                                                    <ItemsControl ItemsSource="{Binding AllTags}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border x:Name="Row"
                                                                        CornerRadius="8"
                                                                        Padding="10,8"
                                                                        Margin="0,1"
                                                                        Cursor="Hand"
                                                                        Background="Transparent">
                                                                    <Border.InputBindings>
                                                                        <MouseBinding MouseAction="LeftClick"
                                                                                      Command="{Binding DataContext.ToggleTagFilterCommand,
                                                                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                      CommandParameter="{Binding Name}"/>
                                                                    </Border.InputBindings>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <!-- Punto de color -->
                                                                        <Border Grid.Column="0"
                                                                                Width="10" Height="10"
                                                                                CornerRadius="5"
                                                                                Background="{Binding Color, Converter={StaticResource HexBrush}}"
                                                                                VerticalAlignment="Center"
                                                                                Margin="0,0,10,0"/>

                                                                        <!-- Nombre -->
                                                                        <TextBlock Grid.Column="1"
                                                                                   Text="{Binding Name}"
                                                                                   FontFamily="Segoe UI"
                                                                                   FontSize="13"
                                                                                   Foreground="{DynamicResource BrushTextPrimary}"
                                                                                   VerticalAlignment="Center"/>

                                                                        <!-- Check cuando está activa -->
                                                                        <TextBlock Grid.Column="2"
                                                                                   x:Name="CheckMark"
                                                                                   Text="✓"
                                                                                   FontSize="13"
                                                                                   FontWeight="Bold"
                                                                                   Foreground="{Binding Color, Converter={StaticResource HexBrush}}"
                                                                                   Visibility="Collapsed"
                                                                                   VerticalAlignment="Center"/>
                                                                    </Grid>
                                                                </Border>

                                                                <DataTemplate.Triggers>
                                                                    <!-- Activa: fondo sutil + checkmark -->
                                                                    <DataTrigger Value="True">
                                                                        <DataTrigger.Binding>
                                                                            <MultiBinding Converter="{StaticResource ColContains}">
                                                                                <Binding Path="DataContext.ActiveTagFilters"
                                                                                         RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                                <Binding Path="Name"/>
                                                                            </MultiBinding>
                                                                        </DataTrigger.Binding>
                                                                        <Setter TargetName="Row"       Property="Background" Value="{DynamicResource BrushBgCard}"/>
                                                                        <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                    <!-- Hover -->
                                                                    <Trigger SourceName="Row" Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Row" Property="Background" Value="{DynamicResource BrushBgCard}"/>
                                                                    </Trigger>
                                                                </DataTemplate.Triggers>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </ScrollViewer>

                                            <!-- Footer: nueva etiqueta -->
                                            <Border BorderBrush="{DynamicResource BrushBorder}"
                                                    BorderThickness="0,1,0,0" Padding="8,8">
                                                <Button Style="{StaticResource BtnIcon}"
                                                        Click="OpenTagDialog_Click"
                                                        Padding="8,6" HorizontalAlignment="Left">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="+" FontSize="14" FontWeight="Bold"
                                                                   Foreground="{DynamicResource BrushAccent}"
                                                                   Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Nueva etiqueta"
                                                                   FontFamily="Segoe UI" FontSize="12"
                                                                   Foreground="{DynamicResource BrushAccent}"/>
                                                    </StackPanel>
                                                </Button>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>

                            <!-- Botón agregar app -->
                            <Button Grid.Column="2" Style="{StaticResource BtnPrimary}"
                                    Command="{Binding AddAppCommand}" Padding="12,6">
                                <TextBlock Text="+ App" FontFamily="Segoe UI" FontSize="12"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Lista de apps -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8,6">
                        <StackPanel>
                            <!-- Indicador de filtros activos (discreto, debajo del header) -->
                            <Border Padding="10,6,10,0"
                                    Visibility="{Binding ActiveTagFilters.Count, Converter={StaticResource NonZeroVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Filtrando por: " FontFamily="Segoe UI" FontSize="11"
                                               Foreground="{DynamicResource BrushTextSecondary}"/>
                                    <ItemsControl ItemsSource="{Binding ActiveTagFilters}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4" Padding="6,2" Margin="0,0,4,0"
                                                        Background="{DynamicResource BrushBgCard}">
                                                    <TextBlock Text="{Binding}" FontFamily="Segoe UI"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource BrushAccent}"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button Style="{StaticResource BtnIcon}" Padding="4,2"
                                            Command="{Binding ClearTagFiltersCommand}">
                                        <TextBlock Text="✕ limpiar" FontFamily="Segoe UI" FontSize="11"
                                                   Foreground="{DynamicResource BrushTextSecondary}"/>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- ★ FAVORITOS — colapsable, solo aparece si hay favoritos -->
                            <Border Visibility="{Binding FavoritesView.IsEmpty, Converter={StaticResource InvBoolVis}}">
                                <StackPanel>
                                    <!-- Header clicable para colapsar -->
                                    <Border Padding="10,8,10,4" Cursor="Hand"
                                            ToolTip="Mostrar/ocultar favoritos">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding ToggleFavoritesCommand}"/>
                                        </Border.InputBindings>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="★" FontSize="10"
                                                       Foreground="{DynamicResource BrushFavActive}"
                                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="FAVORITOS" FontFamily="Segoe UI" FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrushFavActive}"
                                                       VerticalAlignment="Center"/>
                                            <!-- Flecha indicadora de estado -->
                                            <TextBlock FontFamily="Segoe UI" FontSize="9"
                                                       Foreground="{DynamicResource BrushFavActive}"
                                                       VerticalAlignment="Center" Margin="6,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="▲"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ShowFavorites}" Value="False">
                                                                <Setter Property="Text" Value="▼"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <!-- Lista de favoritos (colapsable) -->
                                    <ListBox ItemsSource="{Binding FavoritesView}"
                                             SelectedItem="{Binding SelectedApp}"
                                             Visibility="{Binding ShowFavorites, Converter={StaticResource BoolVis}}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <ContentPresenter ContentTemplate="{StaticResource AppCardTpl}"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <!-- TODAS -->
                            <Border Padding="10,8,10,2">
                                <TextBlock Text="TODAS" FontFamily="Segoe UI" FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrushTextSecondary}"/>
                            </Border>

                            <ListBox ItemsSource="{Binding AppsView}"
                                     SelectedItem="{Binding SelectedApp}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <ContentPresenter ContentTemplate="{StaticResource AppCardTpl}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Vacío -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,40,0,0"
                                        Opacity="0.4"
                                        Visibility="{Binding Apps.Count, Converter={StaticResource ZeroVis}}">
                                <TextBlock Text="Sin aplicaciones" FontFamily="Segoe UI" FontSize="13"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Usa + App para comenzar" FontFamily="Segoe UI" FontSize="11"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Rectangle Grid.Column="1" Fill="{DynamicResource BrushBorder}"/>

                <!-- ══ PANEL DETALLE ══ -->
                <Grid Grid.Column="2" Background="{DynamicResource BrushBgDark}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Opacity="0.22"
                                Visibility="{Binding HasSelectedApp, Converter={StaticResource InvBoolVis}}">
                        <Image Source="pack://application:,,,/Assets/apen_logo.png"
                               Width="80" Height="80" HorizontalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="ApEn" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushAccent}" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" Margin="0,10,0,5"/>
                        <TextBlock Text="Selecciona una aplicación" FontFamily="Segoe UI" FontSize="13"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasSelectedApp, Converter={StaticResource BoolVis}}">
                        <Grid Margin="28,20,28,20" DataContext="{Binding SelectedApp}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Icono + nombre + edit -->
                            <Grid Grid.Row="0" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="52" Height="52" CornerRadius="12"
                                        Background="{DynamicResource BrushBgCard}"
                                        Margin="0,0,16,0" VerticalAlignment="Top">
                                    <Image Source="{Binding Icon}" Width="34" Height="34"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                           FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource BrushTextPrimary}"
                                           TextWrapping="Wrap" VerticalAlignment="Center"
                                           Visibility="{Binding IsEditing, Converter={StaticResource InvBoolVis}}"/>
                                <StackPanel Grid.Column="1"
                                            Visibility="{Binding IsEditing, Converter={StaticResource BoolVis}}">
                                    <TextBox Style="{StaticResource InputBox}"
                                             Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="18" FontWeight="Bold"
                                             KeyDown="AppNameTextBox_KeyDown"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Style="{StaticResource BtnPrimary}"
                                                Command="{Binding CommitEditCommand}"
                                                Padding="14,6" Margin="0,0,6,0">
                                            <TextBlock Text="Guardar" FontFamily="Segoe UI" FontSize="12"/>
                                        </Button>
                                        <Button Style="{StaticResource BtnSecondary}"
                                                Command="{Binding CancelEditCommand}" Padding="14,6">
                                            <TextBlock Text="Cancelar" FontFamily="Segoe UI" FontSize="12"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="2" Style="{StaticResource BtnIcon}"
                                        Command="{Binding StartEditCommand}" Padding="8"
                                        VerticalAlignment="Top"
                                        Visibility="{Binding IsEditing, Converter={StaticResource InvBoolVis}}"
                                        ToolTip="Renombrar en ApEn">
                                    <TextBlock Text="✎" FontSize="15"
                                               Foreground="{DynamicResource BrushTextSecondary}"/>
                                </Button>
                            </Grid>

                            <TextBlock Grid.Row="1" Text="{Binding Path}"
                                       FontFamily="Segoe UI" FontSize="11"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       TextWrapping="Wrap" Margin="0,0,0,18"
                                       ToolTip="{Binding Path}"/>

                            <WrapPanel Grid.Row="2" Margin="0,0,0,18">
                                <Button Style="{StaticResource BtnPrimary}"
                                        Command="{Binding DataContext.LaunchAppCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Padding="22,10" Margin="0,0,8,6">
                                    <TextBlock Text="▶  Ejecutar" FontFamily="Segoe UI" FontSize="13"/>
                                </Button>
                                <Button Style="{StaticResource BtnIcon}"
                                        Command="{Binding ToggleFavCommand}"
                                        Padding="12,10" Margin="0,0,6,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontSize="15" Margin="0,0,5,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"       Value="☆"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource BrushFavInactive}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                            <Setter Property="Text"       Value="★"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource BrushFavActive}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock FontFamily="Segoe UI" FontSize="12"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   Text="{Binding IsFavorite, Converter={StaticResource BoolStr},
                                                          ConverterParameter='Quitar favorito|Favorito'}"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource BtnIcon}"
                                        Command="{Binding DataContext.RemoveAppCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Padding="12,10" Margin="0,0,0,6">
                                    <TextBlock Text="✕  Eliminar" FontFamily="Segoe UI" FontSize="12"
                                               Foreground="{DynamicResource BrushDanger}"/>
                                </Button>
                            </WrapPanel>

                            <Rectangle Grid.Row="3" Height="1"
                                       Fill="{DynamicResource BrushBorder}" Margin="0,0,0,16"/>

                            <!-- Etiquetas del app -->
                            <StackPanel Grid.Row="4">
                                <TextBlock Text="ETIQUETAS" FontFamily="Segoe UI" FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding Tags}" Margin="0,0,0,8">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="9,4" Margin="0,0,5,5"
                                                    Background="{DynamicResource BrushAccent}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding}" FontFamily="Segoe UI"
                                                               FontSize="12" Foreground="White"
                                                               Margin="0,0,5,0"/>
                                                    <Button Style="{StaticResource BtnIcon}" Padding="2"
                                                            Command="{Binding DataContext.SelectedApp.RemoveTagCommand,
                                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="✕" FontSize="10" Foreground="White"/>
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl ItemsSource="{Binding DataContext.AllTags,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                              Visibility="{Binding DataContext.AllTags.Count,
                                                           RelativeSource={RelativeSource AncestorType=Window},
                                                           Converter={StaticResource NonZeroVis}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource BtnSecondary}"
                                                    Padding="9,4" Margin="0,0,5,5"
                                                    Command="{Binding DataContext.AddTagToSelectedCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Name}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="7" Height="7" CornerRadius="4"
                                                            Background="{Binding Color, Converter={StaticResource HexBrush}}"
                                                            Margin="0,0,5,0"/>
                                                    <TextBlock Text="{Binding Name}" FontFamily="Segoe UI"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource BrushTextSecondary}"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Margin="0,4,0,0" FontFamily="Segoe UI" FontSize="11"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           Visibility="{Binding DataContext.AllTags.Count,
                                                        RelativeSource={RelativeSource AncestorType=Window},
                                                        Converter={StaticResource ZeroVis}}">
                                    Usa "🏷 Filtrar → + Nueva etiqueta" para crear
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ─── TAB 1: ORGANIZER ─── -->
            <Grid Visibility="{Binding ActiveTab, Converter={StaticResource TabVis}, ConverterParameter=1}"
                  Background="{DynamicResource BrushBgDark}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="36,26,36,0">
                    <StackPanel>
                        <TextBlock Text="File Organizer" FontSize="22" FontWeight="Bold"
                                   FontFamily="Segoe UI" Foreground="{DynamicResource BrushTextPrimary}"/>
                        <TextBlock Text="Clasifica archivos de una carpeta en subcarpetas por tipo."
                                   FontFamily="Segoe UI" FontSize="13"
                                   Foreground="{DynamicResource BrushTextSecondary}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Padding="36,16,36,0">
                    <Border Background="{DynamicResource BrushBgCard}" CornerRadius="10"
                            Padding="16,12" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                       FontFamily="Segoe UI" FontSize="13"
                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding SelectedFolderPath}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="{Binding SelectedFolderPath}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedFolderPath}" Value="">
                                                <Setter Property="Text"       Value="Ninguna carpeta seleccionada"/>
                                                <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button Grid.Column="1" Style="{StaticResource BtnSecondary}"
                                    Command="{Binding BrowseFolderCommand}" Margin="12,0,8,0" Padding="14,8">
                                <TextBlock Text="Examinar..." FontFamily="Segoe UI" FontSize="13"
                                           Foreground="{DynamicResource BrushTextSecondary}"/>
                            </Button>
                            <Button Grid.Column="2" Style="{StaticResource BtnPrimary}"
                                    Command="{Binding OrganizeFilesCommand}" Padding="18,8">
                                <TextBlock FontFamily="Segoe UI" FontSize="13"
                                           Text="{Binding IsBusy, Converter={StaticResource BoolStr},
                                                  ConverterParameter='Procesando...|⚡ Organizar'}"/>
                            </Button>
                        </Grid>
                    </Border>
                </Border>
                <Border Grid.Row="2" Padding="36,12,36,0"
                        Visibility="{Binding ShowOrganizeResult, Converter={StaticResource BoolVis}}">
                    <Border CornerRadius="10" Padding="20,16">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"      Value="{DynamicResource BrushSuccessBg}"/>
                                <Setter Property="BorderBrush"     Value="{DynamicResource BrushSuccess}"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OrganizeResultIsOk}" Value="False">
                                        <Setter Property="Background"  Value="{DynamicResource BrushErrorBg}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BrushDanger}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontSize="26" VerticalAlignment="Center" Margin="0,0,14,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="✓"/>
                                        <Setter Property="Foreground" Value="{DynamicResource BrushSuccess}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OrganizeResultIsOk}" Value="False">
                                                <Setter Property="Text"       Value="⚠"/>
                                                <Setter Property="Foreground" Value="{DynamicResource BrushDanger}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold"
                                           Text="{Binding OrganizeResultMsg}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource BrushSuccess}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding OrganizeResultIsOk}" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource BrushDanger}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock FontFamily="Segoe UI" FontSize="12" Margin="0,4,0,0"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           Text="Los archivos ya clasificados no se duplicaron."/>
                            </StackPanel>
                            <Button Grid.Column="2" Style="{StaticResource BtnIcon}"
                                    Command="{Binding DismissResultCommand}"
                                    Padding="8" Margin="10,0,0,0" VerticalAlignment="Top">
                                <TextBlock Text="✕" FontSize="12"
                                           Foreground="{DynamicResource BrushTextSecondary}"/>
                            </Button>
                        </Grid>
                    </Border>
                </Border>
                <Border Grid.Row="3" Padding="36,14,36,28">
                    <StackPanel>
                        <TextBlock Text="CATEGORIAS" FontFamily="Segoe UI" FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,10"/>
                        <UniformGrid Columns="4">
                            <Border Margin="4" Background="{DynamicResource BrushBgCard}" CornerRadius="10" Padding="16,14">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="PDF" FontWeight="Bold" FontSize="17" FontFamily="Segoe UI" Foreground="#FFFF5C6A" HorizontalAlignment="Center"/>
                                    <TextBlock Text=".pdf" FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="4" Background="{DynamicResource BrushBgCard}" CornerRadius="10" Padding="16,14">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="IMG" FontWeight="Bold" FontSize="17" FontFamily="Segoe UI" Foreground="#FF48C2A0" HorizontalAlignment="Center"/>
                                    <TextBlock Text=".jpg .png .gif..." FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="4" Background="{DynamicResource BrushBgCard}" CornerRadius="10" Padding="16,14">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="VID" FontWeight="Bold" FontSize="17" FontFamily="Segoe UI" Foreground="#FF6C63FF" HorizontalAlignment="Center"/>
                                    <TextBlock Text=".mp4 .mkv .avi..." FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="4" Background="{DynamicResource BrushBgCard}" CornerRadius="10" Padding="16,14">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="AUD" FontWeight="Bold" FontSize="17" FontFamily="Segoe UI" Foreground="#FFFFB347" HorizontalAlignment="Center"/>
                                    <TextBlock Text=".mp3 .wav .flac..." FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="4" Background="{DynamicResource BrushBgCard}" CornerRadius="10" Padding="16,14">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="DOC" FontWeight="Bold" FontSize="17" FontFamily="Segoe UI" Foreground="#FF48C2A0" HorizontalAlignment="Center"/>
                                    <TextBlock Text=".docx .xlsx .txt..." FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="4" Background="{DynamicResource BrushBgCard}" CornerRadius="10" Padding="16,14">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="ZIP" FontWeight="Bold" FontSize="17" FontFamily="Segoe UI" Foreground="#FFFF5C6A" HorizontalAlignment="Center"/>
                                    <TextBlock Text=".zip .rar .7z..." FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="4" Background="{DynamicResource BrushBgCard}" CornerRadius="10" Padding="16,14">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="ETC" FontWeight="Bold" FontSize="17" FontFamily="Segoe UI" Foreground="{DynamicResource BrushTextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Others" FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource BrushTextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
