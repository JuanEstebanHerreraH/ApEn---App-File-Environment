<Window x:Class="ApEn.Views.TagDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nueva etiqueta"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Background="{DynamicResource BrushBgPanel}"
        ShowInTaskbar="False">

    <StackPanel Margin="20,16,20,20">

        <!-- Nombre -->
        <TextBlock Text="NOMBRE" FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"
                   Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,6"/>
        <TextBox x:Name="TxtName" Style="{StaticResource InputBox}"
                 Padding="10,8" FontSize="14" Margin="0,0,0,18"
                 KeyDown="TxtName_KeyDown"/>

        <!-- Color presets -->
        <TextBlock Text="COLOR" FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"
                   Foreground="{DynamicResource BrushTextSecondary}" Margin="0,0,0,8"/>
        <ItemsControl x:Name="ColorPicker" Margin="0,0,0,10">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <!-- Hex personalizado -->
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="HEX" FontFamily="Segoe UI" FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextSecondary}"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Grid.Column="1" x:Name="TxtHex"
                     Style="{StaticResource InputBox}"
                     Padding="8,6" FontFamily="Consolas" FontSize="13"
                     MaxLength="9"
                     TextChanged="TxtHex_TextChanged"
                     KeyDown="TxtName_KeyDown"/>
            <Border Grid.Column="2" x:Name="ColorPreview"
                    Width="30" Height="30" CornerRadius="8"
                    Margin="8,0,0,0" Background="#FF6C63FF"/>
        </Grid>

        <!-- Botones -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Style="{StaticResource BtnSecondary}"
                    Content="Cancelar" Padding="0,10" Click="Cancel_Click"
                    FontFamily="Segoe UI" FontSize="13"
                    Foreground="{DynamicResource BrushTextSecondary}"/>
            <Button Grid.Column="2" Style="{StaticResource BtnPrimary}"
                    Content="Crear etiqueta" Padding="0,10" Click="Create_Click"
                    FontFamily="Segoe UI" FontSize="13"/>
        </Grid>

    </StackPanel>
</Window>
